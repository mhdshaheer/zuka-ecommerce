<%-include('../../views/partials/admin/adminHeader')%>

  <style>
    .text-truncate {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 150px;
    }

    .nameErr {
      color: red;
      display: none;
      margin-top: -20px;
      padding-bottom: 5px;
      font-size: 13px;
    }
  </style>
  <section class="content-main">
    <div class="content-header">
      <div>
        <h2 class="content-title card-title">Categories</h2>
        <p>Add, edit or delete a category</p>
      </div>
      <div>
        <input type="text" placeholder="Search Categories" class="form-control bg-white" />
      </div>
    </div>
    <div class="card">
      <div class="card-body">
        <div class="row">
          <div class="col-md-3">
            <form id="catForm">
              <div class="mb-4">
                <label for="catName" class="form-label">Name</label>
                <input type="text" placeholder="Type here" class="form-control" id="catName" , name="catName" />
              </div>
              <div id="nameError" class="nameErr"></div>



              <div class="mb-4">
                <label class="form-label">Description</label>
                <textarea placeholder="Type here" class="form-control" , id="description" ,
                  name="description"></textarea>
              </div>
              <div id="descError" class="nameErr"></div>
              <div class="d-grid">
                <button type="submit" class="btn btn-primary">Create category</button>
              </div>
            </form>
          </div>
          <div class="col-md-9">
            <div class="table-responsive">
              <table class="table table-hover">
                <thead>
                  <tr>
                    <th class="text-center">
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" value="" />
                      </div>
                    </th>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Offer Price</th>
                    <th>Add Offer</th>
                    <th>Status</th>
                    <th>Edit</th>

                  </tr>
                </thead>
                <tbody>
                  <%categoryData.forEach((category,index)=>{%>
                    <tr id="categoryRow-<%=category._id%>">
                      <td class="text-center">
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" value="" />
                        </div>
                      </td>
                      <td>
                        <%=index+1%>
                      </td>
                      <td><b>
                          <%=category.name%>
                        </b></td>
                      <td class="text-truncate">
                        <%=category.description%>
                      </td>
                      <td>
                        <%if(category.categoryOffer){%>
                          <%=category.categoryOffer%>%
                            <%}else{%>
                              0%
                              <%}%>
                      </td>
                      <td>
                        <%if(category.categoryOffer==0){%>
                          <a class="btn btn-warning btn-sm" href="javascript:void(0)"
                            onclick="showAddOfferModal('<%=category._id%>')">Add Offer</a>
                          <%}else{%>
                            <a class="btn btn-danger btn-sm" href=""
                              onclick="removeOffer('<%=category._id%>')">Remove</a>
                            <%}%>
                      </td>

                      <td>
                        <%if(category.isListed){%>
                          <span class="badge rounded-pill alert-success">Listed</span>
                          <%}else{%>
                            <span class="badge rounded-pill alert-danger">Unlisted</span>
                            <%}%>
                      </td>
                      <td>
                        <a class="btn btn-primary" href="javascript:void(0)"
                          onclick="editCategoryModal('<%=category._id%>','<%=category.name%>','<%=category.description%>')">Edit</a>
                      </td>


                    </tr>
                    <%})%>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="pagination-area">
      <nav aria-label="Page navigation example">
        <ul class="pagination justify-content-center">
          <% if (currentPage> 1) { %>
            <li class="page-item">
              <a class="page-link" href="/admin/categories?page=<%= currentPage - 1 %>">&laquo; Prev</a>
            </li>
            <% } %>

              <% for (let i=1; i <=totalPages; i++) { %>
                <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                  <a class="page-link" href="/admin/categories?page=<%= i %>">
                    <%= i %>
                  </a>
                </li>
                <% } %>

                  <% if (currentPage < totalPages) { %>
                    <li class="page-item">
                      <a class="page-link" href="/admin/categories?page=<%= currentPage + 1 %>">&raquo; Next </a>
                    </li>
                    <% } %>
        </ul>
      </nav>
    </div>

    <!-- ============modal for add offer ==================== -->

    <!-- Modal for adding new offer -->
    <div class="modal" id="addPriceModal" tabindex="-1" aria-labelledby="addPriceModalLabel" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h3 class="modal-title" id="addPriceModalLabel">Add New Offer</h3>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <form id="addOfferForm">
              <input type="hidden" id="categoryIdInput">

              <div class="mb-3">
                <label for="price" class="form-label">Offer Price</label>
                <input type="number" class="form-control" id="offerPrice" name="price" required value="" min="0" max="100">
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <button type="submit" class="btn btn-primary" id="saveOfferButton">Save Offer</button>
          </div>
        </div>
      </div>
    </div>

    <!-- ============modal end==================== -->

    <!-- =============modal for edit category============ -->
    <!-- Edit Category Modal -->
    <div class="modal" id="editCategoryModal" tabindex="-1" aria-labelledby="editCategoryModalLabel" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h3 class="modal-title" id="editCategoryModalLabel">Edit Category</h3>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <form id="editCategoryForm">
              <input type="hidden" id="categoryIdInput">

              <div class="mb-3">
                <label for="categoryName" class="form-label">Category Name</label>
                <input type="text" class="form-control" id="categoryName" name="name" required>
              </div>

              <div class="mb-3">
                <label for="categoryDescription" class="form-label">Description</label>
                <textarea class="form-control" id="categoryDescription" name="description" required></textarea>
              </div>

              <div class="mb-3">
                <label for="categoryStatus" class="form-label">Status</label>
                <select class="form-control" id="categoryStatus" name="status" required>
                  <option value="listed">Listed</option>
                  <option value="unlisted">Unlisted</option>
                </select>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <button type="submit" class="btn btn-primary" id="saveCategoryButton">Save Changes</button>
          </div>
        </div>
      </div>
    </div>

    <!-- ==============Modal to Edit category end-->


  </section>
  <!-- content-main end// -->
  <footer class="main-footer font-xs">
    <div class="row pb-30 pt-15">
      <div class="col-sm-6">
        <script>
          document.write(new Date().getFullYear());
        </script>
        &copy; Zuka - Sports Ecommerce .
      </div>
      <div class="col-sm-6">
        <div class="text-sm-end">All rights reserved</div>
      </div>
    </div>
  </footer>
  </main>
  <script>
    const catName = document.getElementById('catName');
    const description = document.getElementById('description')
    document.getElementById('catForm').addEventListener('submit', (e) => {
      e.preventDefault()
      const nameError = document.getElementById('nameError')
      const descError = document.getElementById('descError')
      let a = 0;
      const catData = {
        name: catName.value,
        description: description.value
      }

      //validation check for name of the category form data
      if (catName.value.trim() == "") {
        nameError.style.display = 'block',
          nameError.innerHTML = "Name is required"
        a = 1;
      } else {
        nameError.style.display = 'none',
          nameError.innerHTML = ""
        a = 0;
      }

      //validation check for description of the category form data
      if (description.value.trim() == "") {
        descError.style.display = "block",
          descError.innerHTML = "Description is required"
        a = 1;
      } else {
        descError.style.display = "none",
          descError.innerHTML = "";
        a = 0;
      }

      if (a === 1) return;

      Swal.fire({
        title: 'Creating...',
        allowOutsideClick: false,
        didOpen: () => {
          Swal.showLoading();
        }
      });

      axios.post('/admin/categories', catData)
        .then(response => {
          const data = response.data;
          Swal.fire({
            title: 'Success!',
            text: 'Category added successfully!',
            icon: 'success',
            confirmButtonText: 'Okay'
          }).then(() => {
            // Append safely to the table body
            const tbody = document.querySelector('.table tbody');
            const newIndex = tbody.children.length + 1;
            const newRow = document.createElement('tr');
            newRow.id = `categoryRow-${data.category._id}`;
            newRow.innerHTML = `
                <td class="text-center">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" value="" />
                  </div>
                </td>
                <td>${newIndex}</td>
                <td><b>${data.category.name}</b></td>
                <td class="text-truncate">${data.category.description}</td>
                <td>0%</td>
                <td>
                    <a class="btn btn-warning btn-sm" href="javascript:void(0)"
                      onclick="showAddOfferModal('${data.category._id}')">Add Offer</a>
                </td>
                <td>
                    <span class="badge rounded-pill alert-success">Listed</span>
                </td>
                <td>
                  <a class="btn btn-primary" href="javascript:void(0)"
                    onclick="editCategoryModal('${data.category._id}','${data.category.name}','${data.category.description}')">Edit</a>
                </td>
            `;
            tbody.appendChild(newRow);

            // Clean form
            catName.value = '';
            description.value = '';
          });
        })
        .catch(err => {
          Swal.fire({
            title: 'Error!',
            text: err.response?.data?.error || 'Failed to add category',
            icon: 'error',
            confirmButtonText: 'Okay'
          });
        });
    })

    //add offer 
    function showAddOfferModal(id) {
      const price = document.getElementById('offerPrice')
      const saveOfferButton = document.getElementById('saveOfferButton')

      price.value = '';

      const modalElement = document.getElementById('addPriceModal');
      let modal = bootstrap.Modal.getInstance(modalElement);
      if (!modal) {
        modal = new bootstrap.Modal(modalElement);
      }
      modal.show();

      saveOfferButton.onclick = (e) => {
        e.preventDefault();

        if (price.value !== '0' && price.value !== '' && price.value) {
          const offerVal = price.value;

          Swal.fire({
            title: 'Adding offer...',
            allowOutsideClick: false,
            didOpen: () => {
              Swal.showLoading();
            }
          });

          axios.patch(`/admin/categories/${id}/offer`, {
              newPrice: offerVal
          })
            .then(response => {
              modal.hide();
              Swal.fire({
                title: 'Success!',
                text: 'Offer added successfully!',
                icon: 'success',
                confirmButtonText: 'Okay'
              }).then(() => {
                const row = document.getElementById(`categoryRow-${id}`);
                if (row) {
                  row.children[4].textContent = `${offerVal}%`;
                  row.children[5].innerHTML = `<a class="btn btn-danger btn-sm" href="javascript:void(0)" onclick="removeOffer('${id}')">Remove</a>`;
                }
              });
            })
            .catch(err => {
              Swal.fire({
                title: 'Error!',
                text: err.response?.data?.message || 'Failed to add the offer.',
                icon: 'error',
                confirmButtonText: 'Okay'
              });
            });
        } else {
          Swal.fire({
            title: 'Error!',
            text: 'Please enter an offer price.',
            icon: 'error',
            confirmButtonText: 'Okay'
          });
        }
      }
    }

    // Remove offerPrice
    function removeOffer(id) {
      Swal.fire({
        title: 'Are you sure?',
        text: "Do you want to remove the offer?",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#3085d6',
        cancelButtonColor: '#d33',
        confirmButtonText: 'Yes, remove it!'
      }).then((result) => {
        if (result.isConfirmed) {
          Swal.fire({
            title: 'Removing...',
            allowOutsideClick: false,
            didOpen: () => {
              Swal.showLoading();
            }
          });

          axios.delete(`/admin/categories/${id}/offer`)
            .then(response => {
              Swal.fire({
                title: 'Success!',
                text: 'Offer Deleted successfully!',
                icon: 'success',
                confirmButtonText: 'Okay'
              }).then(() => {
                const row = document.getElementById(`categoryRow-${id}`);
                if (row) {
                  row.children[4].textContent = '0%';
                  row.children[5].innerHTML = `<a class="btn btn-warning btn-sm" href="javascript:void(0)" onclick="showAddOfferModal('${id}')">Add Offer</a>`;
                }
              });
            })
            .catch(err => {
              Swal.fire({
                title: 'Error!',
                text: err.response?.data?.message || 'Failed to Remove the offer.',
                icon: 'error',
                confirmButtonText: 'Okay'
              });
            });
        }
      });
    }



    //edit category

    function editCategoryModal(id,catname,catDesc) {
      const categoryName = document.getElementById('categoryName');
      const categoryDescription = document.getElementById('categoryDescription');
      const categoryStatus = document.getElementById('categoryStatus');
      categoryName.value = catname.trim()
      categoryDescription.value = catDesc.trim()

      const modalElement = document.getElementById('editCategoryModal');
      let modal = bootstrap.Modal.getInstance(modalElement);
      if (!modal) {
        modal = new bootstrap.Modal(modalElement);
      }
      modal.show();

      const saveCategoryButton = document.getElementById('saveCategoryButton');
      saveCategoryButton.onclick = (e) => {
        e.preventDefault();

        Swal.fire({
          title: 'Saving...',
          allowOutsideClick: false,
          didOpen: () => {
            Swal.showLoading();
          }
        });

        axios.put(`/admin/categories/${id}`, {
            name: categoryName.value,
            description: categoryDescription.value,
            isListed: categoryStatus.value === 'listed'
        })
          .then(response => {
            const data = response.data;
            modal.hide();
            Swal.fire({
              title: 'Success!',
              text: 'Category Edited successfully!',
              icon: 'success',
              confirmButtonText: 'Okay'
            }).then(() => {
              const row = document.getElementById(`categoryRow-${id}`);
              if (row) {
                row.children[2].innerHTML = `<b>${data.category.name}</b>`;
                row.children[3].textContent = data.category.description;
                row.children[6].innerHTML = data.category.isListed 
                  ? '<span class="badge rounded-pill alert-success">Listed</span>'
                  : '<span class="badge rounded-pill alert-danger">Unlisted</span>';
                
                // Keep the buttons matching
                row.children[7].innerHTML = `
                  <a class="btn btn-primary" href="javascript:void(0)"
                    onclick="editCategoryModal('${data.category._id}','${data.category.name}','${data.category.description}')">Edit</a>
                `;
              }
            });
          })
          .catch(err => {
            Swal.fire({
              title: 'Error!',
              text: err.response?.data?.message || 'Failed to Edit category.',
              icon: 'error',
              confirmButtonText: 'Okay'
            });
          });
      }

    }

    // Pagination without reload
    document.addEventListener('click', (e) => {
      const target = e.target.closest('.page-link');
      if (target) {
        e.preventDefault();
        const url = target.getAttribute('href');
        if (!url) return;

        Swal.fire({
          title: 'Loading...',
          allowOutsideClick: false,
          didOpen: () => {
            Swal.showLoading();
          }
        });

        const fetchUrl = url.includes('?') ? `${url}&ajax=true` : `${url}?ajax=true`;

        axios.get(fetchUrl)
          .then(response => {
            const data = response.data;
            let tbodyHtml = '';
            
            let startIndex = (data.currentPage - 1) * 4;

            data.categoryData.forEach((category, index) => {
              const offerCell = category.categoryOffer ? `${category.categoryOffer}%` : '0%';
              
              let offerAction = '';
              if (category.categoryOffer === 0 || !category.categoryOffer) {
                offerAction = `<a class="btn btn-warning btn-sm" href="javascript:void(0)" onclick="showAddOfferModal('${category._id}')">Add Offer</a>`;
              } else {
                offerAction = `<a class="btn btn-danger btn-sm" href="javascript:void(0)" onclick="removeOffer('${category._id}')">Remove</a>`;
              }
              
              const statusBadge = category.isListed
                ? '<span class="badge rounded-pill alert-success">Listed</span>'
                : '<span class="badge rounded-pill alert-danger">Unlisted</span>';

              tbodyHtml += `
                <tr id="categoryRow-${category._id}">
                  <td class="text-center">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" value="" />
                    </div>
                  </td>
                  <td>${startIndex + index + 1}</td>
                  <td><b>${category.name}</b></td>
                  <td class="text-truncate">${category.description}</td>
                  <td>${offerCell}</td>
                  <td>${offerAction}</td>
                  <td>${statusBadge}</td>
                  <td>
                    <a class="btn btn-primary" href="javascript:void(0)"
                      onclick="editCategoryModal('${category._id}','${category.name}','${category.description}')">Edit</a>
                  </td>
                </tr>
              `;
            });

            document.querySelector('.table tbody').innerHTML = tbodyHtml;

            // Update Pagination Area
            let paginationHtml = '';
            if (data.currentPage > 1) {
              paginationHtml += `
                <li class="page-item">
                  <a class="page-link" href="/admin/categories?page=${data.currentPage - 1}">&laquo; Prev</a>
                </li>
              `;
            }
            for (let i = 1; i <= data.totalPages; i++) {
              paginationHtml += `
                <li class="page-item ${data.currentPage == i ? 'active' : ''}">
                  <a class="page-link" href="/admin/categories?page=${i}">${i}</a>
                </li>
              `;
            }
            if (data.currentPage < data.totalPages) {
              paginationHtml += `
                <li class="page-item">
                  <a class="page-link" href="/admin/categories?page=${data.currentPage + 1}">&raquo; Next </a>
                </li>
              `;
            }
            
            const paginationEl = document.querySelector('.pagination');
            if (paginationEl) {
              paginationEl.innerHTML = paginationHtml;
            }

            Swal.close();
            
            // update browser url without reloading
            window.history.pushState({}, '', url);
          })
          .catch(err => {
            Swal.fire({
              title: 'Error!',
              text: 'Failed to load page.',
              icon: 'error',
              confirmButtonText: 'Okay'
            });
          });
      }
    });

  </script>


  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/admin/assets/js/vendors/jquery-3.6.0.min.js"></script>
  <script src="/admin/assets/js/vendors/bootstrap.bundle.min.js"></script>
  <script src="/admin/assets/js/vendors/select2.min.js"></script>
  <script src="/admin/assets/js/vendors/perfect-scrollbar.js"></script>
  <script src="/admin/assets/js/vendors/jquery.fullscreen.min.js"></script>
  <!-- Main Script -->
  <script src="/admin/assets/js/main.js?v=1.1" type="text/javascript"></script>
  </body>

  </html>
