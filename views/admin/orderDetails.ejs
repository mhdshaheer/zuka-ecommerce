<%-include('../../views/partials/admin/adminHeader')%>
    <style>
        .custom-badge {
            display: inline-block;
            background-color: #28a745;
            color: white;
            padding: 0.3em 0.6em;
            font-size: 0.7rem;
            border-radius: .75rem;
        }

        .badge-cancel {
            background-color: #d62626;
        }

        .fixed-size {
            width: 200px;
            height: 200px;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
        }
    </style>
    <section class="content-main">
        <div class="content-header">
            <div>
                <h2 class="content-title card-title">Order Details</h2>
            </div>
        </div>
        <div class="mb-4">
            <header class="card-header">
                <div class="row gx-3">
                    <div class="col-lg-8 col-md-6 me-auto">
                        <h5>OrderId : <p>#<%=orders.orderId%>
                            </p>
                        </h5>
                    </div>
                    <div class="col-lg-2 col-6 col-md-3">
                        <%if(orders.status=='Cancelled'){%>
                            <button class="btn btn-danger" disabled>cancelled</button>
                        <%}else if(orders.status=='Delivered'){%>
                            <span class="badge rounded-pill alert-primary"><%=orders.status%></span>
                        <%}else if(orders.paymentStatus == 'Failed'){%>
                            <button class="btn btn-secondary" disabled>Status Disabled</button>
                        <%}else{%>
                            <button class="btn btn-secondary" data-bs-toggle="modal" data-bs-target="#statusModal"
                                onclick="updateStatus('<%=orders._id%>','<%=orders.status%>')">Status</button>
                        <%}%>
                    </div>
                </div>
            </header>
        </div>
        <%orders.orderedItems.map((item)=>{%>
            <div class="card mb-4">
                <div class="card-body">
                    <div class="row align-items-center">
                        <!-- Product Image -->
                        <div class="col-md-3 text-center fixed-size">
                            <img src="<%= item.productId && item.productId.images ? item.productId.images[0] : '/admin/assets/imgs/theme/upload.svg' %>" alt="Product Image"
                                class="img-fluid rounded shadow"
                                style="max-width: 100%; max-height: 100%; object-fit: cover; border: 2px solid #ddd; padding: 5px;">
                        </div>
                        <!-- Order Details -->
                        <div class="col-md-5">
                            <h4 class="text-primary">
                                <%= item.productId ? item.productId.productName : 'Product Removed' %>
                            </h4>
                            <p class="text-dark mb-2"><strong>Price:</strong>
                                ₹<%= item.productId ? item.productId.regularPrice.toFixed(0) : 'N/A' %>
                            </p>
                            <p class="text-dark mb-2"><strong>Color:</strong>
                                <%= item.productId ? item.productId.color : 'N/A' %>
                            </p>
                            <p class="text-dark mb-2"><strong>Size:</strong>
                                <%=item.size%>
                            </p>
                            <p class="text-dark mb-2"><strong>Quantity:</strong>
                                <%=item.quantity%>
                            </p>
                            <p class="text-dark mb-2"><strong>Order Date:</strong>
                                <%=orders.createdAt.toLocaleDateString()%>
                            </p>
                        </div>
                        <!-- Shipping Information -->
                        <div class="col-md-4">
                            <p class="text-dark mb-2"><strong>Status:</strong>
                                <%if(orders.status==='Cancelled' ){%>
                                    <span class="badge custom-badge badge-cancel">
                                        <%=orders.status%>
                                    </span>
                                    <%}else{%>
                                        <span class="badge custom-badge">
                                            <%=orders.status%>
                                        </span>
                                        <%}%>
                            </p>
                            <p class="text-dark mb-2"><strong>Payment status:</strong>
                                <%if(orders.paymentStatus==='Cancelled' || orders.paymentStatus==='Failed'){%>
                                    <span class="badge custom-badge badge-cancel">
                                        <%=orders.paymentStatus%>
                                    </span>
                                    <%}else{%>
                                        <span class="badge custom-badge">
                                            <%=orders.paymentStatus%>
                                        </span>
                                        <%}%>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <%})%>
                <% if (orders.status === 'Cancelled' && orders.cancellationReason) { %>
                    <div class="card mb-4 border-danger">
                        <div class="card-header bg-danger text-white">
                            <h5 class="card-title text-white">Cancellation Reason</h5>
                        </div>
                        <div class="card-body">
                            <p class="mb-0 text-dark"><strong>Reason:</strong> <%= orders.cancellationReason %></p>
                        </div>
                    </div>
                <% } %>

                <% if (orders.status === 'Return Request' && orders.returnReason) { %>
                    <div class="card mb-4 border-warning">
                        <div class="card-header bg-warning text-white">
                            <h5 class="card-title text-white">Return Reason</h5>
                        </div>
                        <div class="card-body">
                            <p class="mb-0 text-dark"><strong>Reason:</strong> <%= orders.returnReason %></p>
                        </div>
                    </div>
                <% } %>

                <% if (orders.status === 'Return Rejected' && orders.returnRejectionReason) { %>
                    <div class="card mb-4 border-danger">
                        <div class="card-header bg-danger text-white">
                            <h5 class="card-title text-white">Return Rejected</h5>
                        </div>
                        <div class="card-body">
                            <p class="mb-0 text-dark"><strong>Reason:</strong> <%= orders.returnRejectionReason %></p>
                        </div>
                    </div>
                <% } %>

                <div class="card mb-4">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <!-- Shipping Information -->
                            <div class="col-md-4">
                                <p class="text-dark mb-1"><strong>Total Amount:</strong> <span class="text-secondary">
                                    ₹<%=orders.finalAmount.toFixed(0)%>
                                </span> 
                            </p>
                            <hr>
                            <h6 class="text-dark fs-5">Shipping Information</h6>
                                <p class="text-dark mb-1"><strong>Customer Name:</strong> <span class="text-secondary">
                                        <%= address ? address.name : 'Unknown' %>
                                    </span> </p>
                                <p class="text-dark mb-1"><strong>Shipping Address:</strong> <span
                                        class="text-secondary">
                                        <% if(address) { %>
                                            <%=address.address%>,
                                                <br>
                                                <%=address.city%>,<%=address.state%>,<%=address.country%>
                                                            <br>
                                                            <%=address.pincode%>
                                        <% } else { %>
                                            Address Information Unavailable
                                        <% } %>
                                    </span>
                                </p>
                                <p class="text-dark"><strong>Contact:</strong><span class="text-secondary">
                                        <%= address ? address.phone : 'N/A' %> <br>
                                        <%= address ? address.altPhone : '' %>
                                    </span></p>
                                <br>
                                <p class="text-dark"><strong>Payment Method:</strong><span class="text-secondary">
                                        <%=orders.paymentMethod%>
                                    </span> </p>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- card end// -->

    </section>

    <!-- content-main end// -->
    <footer class="main-footer font-xs">
        <div class="row pb-30 pt-15">
            <div class="col-sm-6">
                <script>
                    document.write(new Date().getFullYear());
                </script>
                &copy;Zuka sports - Ecommerce.
            </div>
            <div class="col-sm-6">
                <div class="text-sm-end">All rights reserved</div>
            </div>
        </div>
    </footer>
    </main>

    <!-- modal for status change -->
    <!-- Button to Trigger Modal -->


    <!-- Modal Structure -->
    <div class="modal fade" id="statusModal" tabindex="-1" aria-labelledby="statusModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <!-- Modal Header -->
                <div class="modal-header">
                    <h5 class="modal-title" id="statusModalLabel">Update Order Status</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <!-- Modal Body -->
                <div class="modal-body">
                    <form id="updateStatusForm">
                        <div class="mb-3">
                            <label for="orderStatus" class="form-label">Order Status</label>
                            <%if(orders.status=='Pending'){%>
                                <select class="form-select" id="orderStatus" name="status" required>
                                    <option value="Pending" selected>Pending</option>
                                    <option value="Processing">Processing</option>
                                    <option value="Shipped">Shipped</option>
                                    <option value="Delivered">Delivered</option>
                                    <option value="Cancelled">Cancelled</option>
                                </select>
                            <%}else if(orders.status=='Processing'){%>
                                <select class="form-select" id="orderStatus" name="status" required>
                                    <option value="Processing" selected>Processing</option>
                                    <option value="Shipped">Shipped</option>
                                    <option value="Delivered">Delivered</option>
                                    <option value="Cancelled">Cancelled</option>
                                </select>
                                <%}else if(orders.status=='Shipped'){%>
                                    <select class="form-select" id="orderStatus" name="status" required>
                                        <option value="Shipped" selected>Shipped</option>
                                        <option value="Delivered">Delivered</option>
                                        <option value="Cancelled">Cancelled</option>
                                    </select>
                                    
                                        <%}else if(orders.status=='Return Request'){%>
                                            <select class="form-select" id="orderStatus" name="status" required onchange="toggleRejectionReason(this.value)">
                                                <option value="Return Request" selected>Return Request</option>
                                                <option value="Returned">Returned</option>
                                                <option value="Return Rejected">Return Rejected</option>
                                            </select>
                                            <div id="rejectionReasonDiv" style="display: none;" class="mt-3">
                                                <label for="rejectionReason" class="form-label">Return Rejection Reason</label>
                                                <textarea class="form-control" id="rejectionReason" name="rejectionReason"></textarea>
                                            </div>
                            <%}%>
                        </div>
                        <input type="hidden" id="orderId" name="order_id" value="">
                    </form>
                </div>
                <!-- Modal Footer -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" id="updateStatusButton">Update</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ============================= -->

    <script>
        function toggleRejectionReason(status) {
            const div = document.getElementById('rejectionReasonDiv');
            if (div) {
                div.style.display = status === 'Return Rejected' ? 'block' : 'none';
            }
        }

        function updateStatus(order_id, orderStatus) {
            const statusOption = document.getElementById('orderStatus')
            statusOption.value = orderStatus;
            toggleRejectionReason(orderStatus);

            const updateStatusBtn = document.getElementById('updateStatusButton');
            updateStatusBtn.onclick = (e) => {
                e.preventDefault();
                const newStatus = statusOption.value;
                const reason = document.getElementById('rejectionReason') ? document.getElementById('rejectionReason').value : '';

                if (newStatus === 'Return Rejected' && !reason.trim()) {
                    Swal.fire('Error', 'Please provide a reason for rejecting the return.', 'error');
                    return;
                }

                Swal.fire({
                    title: 'Are you sure!',
                    text: 'Do you want to change status!',
                    icon: 'warning',
                    confirmButtonText: 'Yes,Proceed',
                    showCancelButton: true,
                    cancelButtonText: 'Cancel'
                })
                    .then((result) => {
                        if (result.isConfirmed) {
                            axios.patch(`/admin/orders/${order_id}/status`,{
                                status : newStatus,
                                reason : reason
                            })
                            .then(res=>{
                                if(res.status==200){
                                    Swal.fire({
                                    title: 'Success!',
                                    text: 'Status Updated successfully!',
                                    icon: 'success',
                                    confirmButtonText: 'Okay'
                                })
                                .then(()=>{
                                    window.location.reload()
                                })
                                }
                            })
                            .catch(err => {
                                Swal.fire('Error', err.response?.data?.message || 'Failed to update status', 'error');
                            })
                        }
                    })
            }
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/admin/assets/js/vendors/jquery-3.6.0.min.js"></script>
    <script src="/admin/assets/js/vendors/bootstrap.bundle.min.js"></script>
    <script src="/admin/assets/js/vendors/select2.min.js"></script>
    <script src="/admin/assets/js/vendors/perfect-scrollbar.js"></script>
    <script src="/admin/assets/js/vendors/jquery.fullscreen.min.js"></script>
    <!-- Main Script -->
    <script src="/admin/assets/js/main.js?v=1.1" type="text/javascript"></script>
    </body>

    </html>
