<%-include('../../views/partials/admin/adminHeader')%>
    <style>
        .unblockBtn {
            background-color: red;
        }
    </style>


    <section class="content-main">
        <div class="content-header">
            <h2 class="content-title">Users list</h2>
           
        </div>
        <div class="card mb-4">
            <header class="card-header">
                <div class="row gx-3">
                    <div class="col-lg-4 col-md-6 me-auto">
                        <div class="input-group">
                            <input type="text" placeholder="Search by name or email..." class="form-control" id="customerSearch" value="<%= locals.search || '' %>">
                            <button class="btn btn-light bg-white" type="button" onclick="fetchCustomers(1)"><i class="material-icons md-search"></i></button>
                        </div>
                    </div>
                </div>
            </header>
            <!-- card-header end// -->
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Email</th>
                                <th>Status</th>
                                <th>Registered</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody id="customerTableBody">
                            <%for(let i=0;i<userData.length;i++){%>
                                <tr>
                                    <td width="40%">
                                        <div class="info pl-3">
                                            <h6 class="mb-0 title"><%=userData[i].name%></h6>
                                        </div>
                                    </td>
                                    <td><%=userData[i].email%></td>
                                    <td>
                                        <span class="badge rounded-pill <%= userData[i].isBlocked ? 'alert-danger' : 'alert-success' %>">
                                            <%= userData[i].isBlocked ? 'Blocked' : 'Active' %>
                                        </span>
                                    </td>
                                    <td><%=userData[i].createdAt ? userData[i].createdAt.toLocaleDateString() : 'N/A' %></td>
                                    <td class="text-end">
                                        <%if(userData[i].isBlocked==false){%>
                                            <button onclick="confirmBlock('<%=userData[i]._id%>')" class="btn btn-sm btn-brand rounded font-sm mt-15">BLOCK</button>
                                        <%}else {%>
                                            <button onclick="confirmUnBlock('<%=userData[i]._id%>')" class="btn btn-danger btn-sm btn-brand rounded font-sm mt-15 unblockBtn">UNBLOCK</button>
                                        <%}%>
                                    </td>
                                </tr>
                            <%}%>
                        </tbody>
                    </table>
                    <!-- table-responsive.// -->
                </div>
            </div>
            <!-- card-body end// -->
        </div>
        <!-- card end// -->
        <div class="pagination-area mt-15 mb-50">
            <nav aria-label="Page navigation example">
                <ul class="pagination justify-content-start">
                    <% const searchParam = locals.search ? `&search=${locals.search}` : '' %>
                    <li class="page-item <%= (currentPage === 1) ? 'disabled' : '' %>">
                        <a class="page-link" href="?page=<%= currentPage - 1 %><%= searchParam %>">
                            <i class="material-icons md-chevron_left"></i>
                        </a>
                    </li>
                    <% for (let i=1; i <=totalPages; i++) { %>
                        <li class="page-item <%= (i === currentPage) ? 'active' : '' %>">
                            <a class="page-link" href="?page=<%= i %><%= searchParam %>">
                                <%= i %>
                            </a>
                        </li>
                    <% } %>
                    <li class="page-item <%= (currentPage === totalPages || totalPages === 0) ? 'disabled' : '' %>">
                        <a class="page-link" href="?page=<%= currentPage + 1 %><%= searchParam %>">
                            <i class="material-icons md-chevron_right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </section>
    <!-- content-main end// -->
    <footer class="main-footer font-xs">
        <div class="row pb-30 pt-15">
            <div class="col-sm-6">
                <script>
                    document.write(new Date().getFullYear());
                </script>
                &copy; Zuka sports - Ecommerce.
            </div>
            <div class="col-sm-6">
                <div class="text-sm-end">All rights reserved</div>
            </div>
        </div>
    </footer>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const searchInput = document.getElementById('customerSearch');
        const customerTableBody = document.getElementById('customerTableBody');
        const paginationArea = document.querySelector('.pagination-area');

        async function fetchCustomers(page = 1) {
            const search = searchInput.value.trim();
            const url = `/admin/customers?page=${page}&search=${search}&ajax=true`;

            Swal.fire({
                title: 'Loading results...',
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });

            try {
                const response = await axios.get(url);
                const { userData, currentPage, totalPages, search: currentSearch } = response.data;
                updateTable(userData);
                updatePagination(currentPage, totalPages, currentSearch);
                window.history.pushState({}, '', `/admin/customers?page=${currentPage}&search=${currentSearch}`);
                Swal.close();
            } catch (error) {
                console.error("Fetch customers error:", error);
                let errorMsg = "Failed to fetch customer data";
                if (error.response && error.response.data && error.response.data.error) {
                    errorMsg = `Server error: ${error.response.data.error}`;
                }
                Swal.fire('Error', errorMsg, 'error');
            }
        }

        function updateTable(users) {
            customerTableBody.innerHTML = users.length ? users.map(user => `
                <tr>
                    <td width="40%">
                        <div class="info pl-3">
                            <h6 class="mb-0 title">${user.name}</h6>
                        </div>
                    </td>
                    <td>${user.email}</td>
                    <td>
                        <span class="badge rounded-pill ${user.isBlocked ? 'alert-danger' : 'alert-success'}">
                            ${user.isBlocked ? 'Blocked' : 'Active'}
                        </span>
                    </td>
                    <td>${user.createdAt ? new Date(user.createdAt).toLocaleDateString() : 'N/A'}</td>
                    <td class="text-end">
                        ${!user.isBlocked ? 
                            `<button onclick="confirmBlock('${user._id}')" class="btn btn-sm btn-brand rounded font-sm mt-15">BLOCK</button>` : 
                            `<button onclick="confirmUnBlock('${user._id}')" class="btn btn-danger btn-sm btn-brand rounded font-sm mt-15 unblockBtn">UNBLOCK</button>`
                        }
                    </td>
                </tr>
            `).join('') : '<tr><td colspan="5" class="text-center">No customers found</td></tr>';
        }

        function updatePagination(currentPage, totalPages, search) {
            const searchParam = search ? `&search=${search}` : '';
            let html = '<nav aria-label="Page navigation example"><ul class="pagination justify-content-start">';
            
            html += `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                <a class="page-link" href="?page=${currentPage - 1}${searchParam}"><i class="material-icons md-chevron_left"></i></a>
            </li>`;

            for (let i = 1; i <= totalPages; i++) {
                html += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                    <a class="page-link" href="?page=${i}${searchParam}">${i}</a>
                </li>`;
            }

            html += `<li class="page-item ${currentPage === totalPages || totalPages === 0 ? 'disabled' : ''}">
                <a class="page-link" href="?page=${currentPage + 1}${searchParam}"><i class="material-icons md-chevron_right"></i></a>
            </li>`;

            html += '</ul></nav>';
            paginationArea.innerHTML = html;
        }

        searchInput.addEventListener('input', debounce(() => fetchCustomers(1), 500));

        function debounce(func, wait) {
            let timeout;
            return function(...args) {
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(this, args), wait);
            };
        }

        document.addEventListener('click', (e) => {
            const link = e.target.closest('.page-link');
            if (link) {
                e.preventDefault();
                const url = new URL(link.href, window.location.origin);
                const page = url.searchParams.get('page');
                fetchCustomers(page);
            }
        });

        async function confirmBlock(userId) {
            const result = await Swal.fire({
                title: 'Are you sure?',
                text: "Do you really want to block this user?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, block!',
                cancelButtonText: 'Cancel'
            });

            if (result.isConfirmed) {
                try {
                    const response = await axios.patch('/admin/customers/' + userId + '/block');
                    if (response.data.success) {
                        Swal.fire('Blocked!', 'User has been blocked.', 'success');
                        fetchCustomers(new URLSearchParams(window.location.search).get('page') || 1);
                    }
                } catch (error) {
                    Swal.fire('Error', 'Failed to block user', 'error');
                }
            }
        }

        async function confirmUnBlock(userId) {
            const result = await Swal.fire({
                title: 'Are you sure?',
                text: "Do you really want to unblock this user?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, unblock!',
                cancelButtonText: 'Cancel'
            });

            if (result.isConfirmed) {
                try {
                    const response = await axios.patch('/admin/customers/' + userId + '/unblock');
                    if (response.data.success) {
                        Swal.fire('Unblocked!', 'User has been unblocked.', 'success');
                        fetchCustomers(new URLSearchParams(window.location.search).get('page') || 1);
                    }
                } catch (error) {
                    Swal.fire('Error', 'Failed to unblock user', 'error');
                }
            }
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="/admin/assets/js/vendors/jquery-3.6.0.min.js"></script>
    <script src="/admin/assets/js/vendors/bootstrap.bundle.min.js"></script>
    <script src="/admin/assets/js/vendors/select2.min.js"></script>
    <script src="/admin/assets/js/vendors/perfect-scrollbar.js"></script>
    <script src="/admin/assets/js/vendors/jquery.fullscreen.min.js"></script>
    <!-- Main Script -->
    <script src="/admin/assets/js/main.js?v=1.1" type="text/javascript"></script>
    </body>

    </html>
