<%-include('../../views/partials/admin/adminHeader')%>

    <style>
        .img-sm {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 8px;
        }
        .table > :not(caption) > * > * {
            padding: 1rem 0.75rem;
        }
        .product-name {
            font-weight: 600;
            color: #1a1a1a;
            max-width: 200px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .action-btns .btn {
            margin: 2px;
            padding: 0.25rem 0.5rem;
            font-size: 0.75rem;
        }
        .badge-status {
            font-size: 0.7rem;
            padding: 0.35em 0.65em;
        }
    </style>
    <section class="content-main">
        <div class="content-header">
            <div>
                <h2 class="content-title card-title">Products List</h2>
                <p>Product Mangement</p>
            </div>
            <div>
                <a href="/admin/products" class="btn btn-primary btn-sm rounded">Create new</a>
            </div>
        </div>
        <div class="card mb-4">
            <header class="card-header">
                <div class="row gx-3">
                    <div class="col-lg-4 col-md-6 me-auto">
                        <input type="text" placeholder="Search products..." class="form-control" id="searchInput">
                    </div>
                </div>
            </header>
            <!-- card-header end// -->
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th scope="col" class="text-center">No</th>
                                <th scope="col">Product</th>
                                <th scope="col">Price</th>
                                <th scope="col">Status</th>
                                <th scope="col">Added Date</th>
                                <th scope="col" class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="productTableBody">
                            <%for(let i=0;i<products.length;i++){%>
                                <tr>
                                    <td class="text-center">
                                        <span class="text-muted"><%= (currentPage - 1) * limit + i + 1 %></span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="<%=products[i].images[0]%>" alt="<%=products[i].productName%>" class="img-sm me-3 border" />
                                            <div>
                                                <h6 class="mb-0 product-name"><%=products[i].productName%></h6>
                                                <small class="text-muted"><%=products[i].color%></small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="fw-bold">₹<%=products[i].regularPrice.toFixed(0)%></div>
                                        <% if(products[i].offerPrice < products[i].regularPrice) { %>
                                            <small class="text-success">Now: ₹<%=products[i].offerPrice.toFixed(0)%></small>
                                        <% } %>
                                    </td>
                                    <td>
                                        <%if(products[i].isBlocked==false){%>
                                            <span class="badge rounded-pill alert-success badge-status">Active</span>
                                        <%}else{%>
                                            <span class="badge rounded-pill alert-danger badge-status">Blocked</span>
                                        <%}%>
                                    </td>
                                    <td>
                                        <span class="text-muted small"><%=products[i].createdAt.toLocaleDateString()%></span>
                                    </td>
                                    <td class="text-end">
                                        <div class="action-btns">
                                            <button class="btn btn-outline-primary btn-edit-product" 
                                                data-id="<%=products[i]._id%>"
                                                data-name="<%=products[i].productName%>"
                                                data-price="<%=products[i].regularPrice%>"
                                                data-offer="<%=products[i].offerPrice%>"
                                                data-color="<%=products[i].color%>"
                                                data-desc="<%=products[i].description%>"
                                                data-category="<%=products[i].category ? products[i].category.name : ''%>">
                                                <i class="fa-solid fa-pen-to-square"></i>
                                            </button>
                                            <button class="btn btn-outline-info btn-edit-images"
                                                data-id="<%=products[i]._id%>"
                                                data-images='<%= products[i].images.length > 0 ? JSON.stringify(products[i].images) : "[]" %>'>
                                                <i class="fa-solid fa-image"></i>
                                            </button>
                                            <a href="/admin/products/<%=products[i]._id%>/variants/0/edit" class="btn btn-outline-secondary">
                                                <i class="fa-solid fa-layer-group"></i>
                                            </a>
                                            <%if(products[i].isBlocked){%>
                                                <button class="btn btn-soft-success btn-unblock-product" data-id="<%=products[i]._id%>">
                                                    <i class="fa-solid fa-unlock"></i>
                                                </button>
                                            <%}else{%>
                                                <button class="btn btn-soft-danger btn-block-product" data-id="<%=products[i]._id%>">
                                                    <i class="fa-solid fa-lock"></i>
                                                </button>
                                            <%}%>
                                        </div>
                                    </td>
                                </tr>
                            <%}%>
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
        <div class="pagination-area mt-30 mb-50" id="paginationArea">
            <nav aria-label="Page navigation example">
                <ul class="pagination justify-content-start">
                    <% if (currentPage> 1) { %>
                        <li class="page-item">
                            <a class="page-link" href="?page=<%= currentPage - 1 %>">Previous</a>
                        </li>
                        <% } %>

                            <% for (let i=1; i <=totalPages; i++) { %>
                                <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                                    <a class="page-link" href="?page=<%= i %>">
                                        <%= i %>
                                    </a>
                                </li>
                                <% } %>

                                    <% if (currentPage < totalPages) { %>
                                        <li class="page-item">
                                            <a class="page-link" href="?page=<%= currentPage + 1 %>">Next</a>
                                        </li>
                                        <% } %>
                </ul>
            </nav>
        </div>
    </section>
    <footer class="main-footer font-xs">
        <div class="row pb-30 pt-15">
            <div class="col-sm-6">
                <script>
                    document.write(new Date().getFullYear());
                </script>
                &copy;Zuka sports - Ecommerce.
            </div>
            <div class="col-sm-6">
                <div class="text-sm-end">All rights reserved</div>
            </div>
        </div>
    </footer>
    </main>

    <!-- modal -->

    <div class="modal fade" id="productModal" tabindex="-1" aria-labelledby="productModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="productModalLabel">Edit Product</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <!-- Product Details Form -->
                    <form id="editProductForm">
                        <div class="mb-3">
                            <label for="productName" class="form-label">Product Name</label>
                            <input type="text" class="form-control" id="productName">
                        </div>
                        <div class="mb-3">
                            <label for="description" class="form-label">Description</label>
                            <textarea class="form-control" id="description" rows="3"></textarea>
                        </div>
                        <div class="mb-3">
                            <label for="category" class="form-label">Category</label>
                            <select class="form-select" id="category">
                                <option value="">Select Category</option>
                                <%for(let i=0;i<category.length;i++){%>
                                    <option>
                                        <%=category[i].name%>
                                    </option>
                                    <%}%>
                            </select>
                        </div>
                        <div class="mb-3 row">
                            <div class="col-sm-6">
                                <label for="regularPrice" class="form-label">Regular Price</label>
                                <input type="number" class="form-control w-100" id="regularPrice" value="">
                            </div>
                            <div class="col-sm-6">
                                <label for="offerPrice" class="form-label">Offer</label>
                                <input type="number" class="form-control w-100" id="offerPrice" value="0">
                            </div>
                        </div>

                        <div class="mb-3 row">
                            <div class="col-sm-6">
                                <label for="color" class="form-label">Color</label>
                                <input type="text" class="form-control w-100" id="color">
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" id="saveChangesBtn">Save changes</button>
                </div>
            </div>
        </div>
    </div>


    <!-- modal end -->

    <div class="modal fade" id="imageUploadModal" tabindex="-1" aria-labelledby="imageUploadModalLabel"
        aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="imageUploadModalLabel">Manage Images and Variants</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <!-- Image Upload Fields -->
                    <div class="row mb-3">
                        <!-- Image 1 -->
                        <div class="col-md-6">
                            <label for="image1" class="form-label">Upload Image 1</label>
                            <input type="file" class="form-control" id="image1" accept="image/*"
                                onchange="previewImage(this, 'preview1')">
                            <div id="preview1" class="image-preview mt-2"
                                style="border: 1px dashed #ccc; padding: 10px; text-align: center;">
                                <img id="imgDiv1" src="" alt="No image uploaded">
                            </div>
                            <button type="button" class="btn btn-primary mt-2" onclick="openCropModal('image1')">Crop</button>
                        </div>
                        <!-- Image 2 -->
                        <div class="col-md-6">
                            <label for="image2" class="form-label">Upload Image 2</label>
                            <input type="file" class="form-control" id="image2" accept="image/*"
                                onchange="previewImage(this, 'preview2')">
                            <div id="preview2" class="image-preview mt-2"
                                style="border: 1px dashed #ccc; padding: 10px; text-align: center;">
                                <img id="imgDiv2" src="" alt="No image uploaded">
                            </div>
                            <button type="button" class="btn btn-primary mt-2" onclick="openCropModal('image2')">Crop</button>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <!-- Image 3 -->
                        <div class="col-md-6">
                            <label for="image3" class="form-label">Upload Image 3</label>
                            <input type="file" class="form-control" id="image3" accept="image/*"
                                onchange="previewImage(this, 'preview3')">
                            <div id="preview3" class="image-preview mt-2"
                                style="border: 1px dashed #ccc; padding: 10px; text-align: center;">
                                <img id="imgDiv3" src="" alt="">
                            </div>
                            <button type="button" class="btn btn-primary mt-2" onclick="openCropModal('image3')">Crop</button>
                        </div>
                        <!-- Image 4 -->
                        <div class="col-md-6">
                            <label for="image4" class="form-label">Upload Image 4</label>
                            <input type="file" class="form-control" id="image4" accept="image/*"
                                onchange="previewImage(this, 'preview4')">
                            <div id="preview4" class="image-preview mt-2"
                                style="border: 1px dashed #ccc; padding: 10px; text-align: center;">
                                <img id="imgDiv4" src="" alt="">
                            </div>
                            <button type="button" class="btn btn-primary mt-2" onclick="openCropModal('image4')">Crop</button>
                        </div>
                    </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" id="updateImageId">Update Images</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Crop Modal -->
    <div class="modal fade" id="cropModal" tabindex="-1" aria-labelledby="cropModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="cropModalLabel">Crop Image</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center">
                    <canvas id="cropCanvas" style="max-width: 100%; max-height: 500px;"></canvas>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button id="saveCrop" type="button" class="btn btn-primary">Save Crop</button>
                </div>
            </div>
        </div>
    </div>
    <!-- Crop Modal -->


    <!-- ======================crop modal======================== -->



    <script>
        // Search functionality
        document.getElementById('searchInput').addEventListener('keyup', function() {
            let filter = this.value.toUpperCase();
            let trs = document.querySelectorAll('tbody tr');
            trs.forEach(tr => {
                let name = tr.querySelector('.product-name').textContent.toUpperCase();
                tr.style.display = name.includes(filter) ? "" : "none";
            });
        });

        let currentProductId = null;

        // Edit product
        document.querySelectorAll('.btn-edit-product').forEach(btn => {
            btn.addEventListener('click', function() {
                const { id, name, price, offer, color, desc, category } = this.dataset;
                currentProductId = id;
                
                document.getElementById('productName').value = name;
                document.getElementById('regularPrice').value = price;
                document.getElementById('description').value = desc;
                document.getElementById('color').value = color;
                document.getElementById('category').value = category;
                
                // Calculating discount percentage
                const regPrice = parseFloat(price);
                const offPrice = parseFloat(offer);
                document.getElementById('offerPrice').value = Math.floor(((regPrice - offPrice) / regPrice) * 100);
                
                var modal = new bootstrap.Modal(document.getElementById('productModal'));
                modal.show();
            });
        });

        document.getElementById('saveChangesBtn').addEventListener('click', (e) => {
            e.preventDefault();
            const offerPerc = document.getElementById('offerPrice').value;

            if(offerPerc > 100 || offerPerc < 0){
                return Swal.fire({
                    title: 'Warning!',
                    text: 'Offer must be between 0 and 100!',
                    icon: 'warning',
                    confirmButtonText: 'Okay'
                });
            }

            const options = {
                productName: document.getElementById('productName').value,
                description: document.getElementById('description').value,
                category: document.getElementById('category').value,
                regularPrice: document.getElementById('regularPrice').value,
                offerPrice: offerPerc,
                color: document.getElementById('color').value
            };

            Swal.fire({
                title: 'Updating...',
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });

            fetch(`/admin/products/${currentProductId}`, {
                method: "PUT",
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(options)
            })
            .then(res => res.json())
            .then(data => {
                Swal.fire({
                    title: 'Success!',
                    text: 'Product Updated successfully!',
                    icon: 'success',
                    confirmButtonText: 'Okay'
                }).then(() => window.location.reload());
            })
            .catch(err => {
                Swal.fire({
                    title: 'Error!',
                    text: 'Failed to update product.',
                    icon: 'error',
                    confirmButtonText: 'Okay'
                });
            });
        });

        // Block/Unblock
        document.querySelectorAll('.btn-block-product').forEach(btn => {
            btn.addEventListener('click', function(e) {
                confirmBlock(e, this.dataset.id);
            });
        });

        document.querySelectorAll('.btn-unblock-product').forEach(btn => {
            btn.addEventListener('click', function(e) {
                confirmUnBlock(e, this.dataset.id);
            });
        });

        async function confirmBlock(event, id) {
            Swal.fire({
                title: 'Are you sure?',
                text: "Product will be hidden from customers!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, block it!'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Processing...',
                        allowOutsideClick: false,
                        didOpen: () => Swal.showLoading()
                    });
                    let response = await fetch('/admin/products/' + id + '/block', { method: 'PATCH' });
                    if(response.ok) window.location.reload();
                }
            });
        }
        
        async function confirmUnBlock(event, id) {
            Swal.fire({
                title: 'Are you sure?',
                text: "Product will be visible to customers!",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, unblock it!'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Processing...',
                        allowOutsideClick: false,
                        didOpen: () => Swal.showLoading()
                    });
                    let response = await fetch('/admin/products/' + id + '/unblock', { method: 'PATCH' });
                    if(response.ok) window.location.reload();
                }
            });
        }

        // Image managed
        document.querySelectorAll('.btn-edit-images').forEach(btn => {
            btn.addEventListener('click', function() {
                currentProductId = this.dataset.id;
                const images = JSON.parse(this.dataset.images);
                
                for(let i=0; i<4; i++){
                    const imgEl = document.getElementById(`imgDiv${i+1}`);
                    if(images[i]) {
                        imgEl.src = images[i];
                        imgEl.style.display = "block";
                    } else {
                        imgEl.src = "";
                        imgEl.style.display = "none";
                    }
                }
                
                var modal = new bootstrap.Modal(document.getElementById('imageUploadModal'));
                modal.show();
            });
        });

        document.getElementById('updateImageId').addEventListener('click', (e) => {
            e.preventDefault();
            const formData = new FormData();
            const imageInputs = [
                document.getElementById('image1'),
                document.getElementById('image2'),
                document.getElementById('image3'),
                document.getElementById('image4'),
            ];

            imageInputs.forEach(input => {
                if(input.files.length > 0) {
                    formData.append('images', input.files[0]);
                }
            });

            Swal.fire({
                title: 'Uploading...',
                allowOutsideClick: false,
                didOpen: () => Swal.showLoading()
            });

            fetch(`/admin/products/${currentProductId}/images`, {
                method: 'PATCH',
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                Swal.fire({
                    title: 'Success!',
                    text: 'Images updated successfully!',
                    icon: 'success',
                    confirmButtonText: 'Okay'
                }).then(() => window.location.reload());
            })
            .catch(err => {
                Swal.fire({ title: 'Error!', text: 'Failed to update images.', icon: 'error' });
            });
        });

        function previewImage(input, previewId) {
            const previewDiv = document.getElementById(previewId);
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = (e) => {
                    previewDiv.innerHTML = `<img src="${e.target.result}" alt="Preview" style="max-width: 100%; height: auto;">`;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Pagination AJAX
        document.addEventListener('click', (e) => {
            const target = e.target.closest('.page-link');
            if (target) {
                e.preventDefault();
                const url = new URL(target.href);
                url.searchParams.set('ajax', 'true');

                Swal.fire({
                    title: 'Loading Products...',
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });

                axios.get(url.toString())
                    .then(response => {
                        const { products, currentPage, totalPages, limit } = response.data;
                        updateTable(products, currentPage, limit);
                        updatePagination(currentPage, totalPages);
                        window.history.pushState({}, '', target.href);
                        Swal.close();
                    })
                    .catch(err => {
                        console.error(err);
                        window.location.href = target.href;
                    });
            }
        });

        function updateTable(products, currentPage, limit) {
            const tbody = document.getElementById('productTableBody');
            tbody.innerHTML = products.map((product, i) => `
                <tr>
                    <td class="text-center">
                        <span class="text-muted">${(currentPage - 1) * limit + i + 1}</span>
                    </td>
                    <td>
                        <div class="d-flex align-items-center">
                            <img src="${product.images[0]}" alt="${product.productName}" class="img-sm me-3 border" />
                            <div>
                                <h6 class="mb-0 product-name">${product.productName}</h6>
                                <small class="text-muted">${product.color}</small>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="fw-bold">₹${product.regularPrice.toFixed(0)}</div>
                        ${product.offerPrice < product.regularPrice ? `<small class="text-success">Now: ₹${product.offerPrice.toFixed(0)}</small>` : ''}
                    </td>
                    <td>
                        <span class="badge rounded-pill ${product.isBlocked ? 'alert-danger' : 'alert-success'} badge-status">
                            ${product.isBlocked ? 'Blocked' : 'Active'}
                        </span>
                    </td>
                    <td>
                        <span class="text-muted small">${new Date(product.createdAt).toLocaleDateString()}</span>
                    </td>
                    <td class="text-end">
                        <div class="action-btns">
                            <button class="btn btn-outline-primary btn-edit-product" 
                                data-id="${product._id}"
                                data-name="${product.productName}"
                                data-price="${product.regularPrice}"
                                data-offer="${product.offerPrice}"
                                data-color="${product.color}"
                                data-desc="${product.description}"
                                data-category="${product.category ? product.category.name : ''}">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </button>
                            <button class="btn btn-outline-info btn-edit-images"
                                data-id="${product._id}"
                                data-images='${JSON.stringify(product.images)}'>
                                <i class="fa-solid fa-image"></i>
                            </button>
                            <a href="/admin/products/${product._id}/variants/0/edit" class="btn btn-outline-secondary">
                                <i class="fa-solid fa-layer-group"></i>
                            </a>
                            ${product.isBlocked ? `
                                <button class="btn btn-soft-success btn-unblock-product" data-id="${product._id}">
                                    <i class="fa-solid fa-unlock"></i>
                                </button>
                            ` : `
                                <button class="btn btn-soft-danger btn-block-product" data-id="${product._id}">
                                    <i class="fa-solid fa-lock"></i>
                                </button>
                            `}
                        </div>
                    </td>
                </tr>
            `).join('');
            
            // Re-bind listeners for newly created buttons
            attachActionListeners();
        }

        function updatePagination(currentPage, totalPages) {
            const paginationArea = document.getElementById('paginationArea');
            let paginationHtml = '<nav aria-label="Page navigation example"><ul class="pagination justify-content-start">';
            
            if (currentPage > 1) {
                paginationHtml += `<li class="page-item"><a class="page-link" href="?page=${currentPage - 1}">Previous</a></li>`;
            }

            for (let i = 1; i <= totalPages; i++) {
                paginationHtml += `
                    <li class="page-item ${i === currentPage ? 'active' : ''}">
                        <a class="page-link" href="?page=${i}">${i}</a>
                    </li>
                `;
            }

            if (currentPage < totalPages) {
                paginationHtml += `<li class="page-item"><a class="page-link" href="?page=${currentPage + 1}">Next</a></li>`;
            }

            paginationHtml += '</ul></nav>';
            paginationArea.innerHTML = paginationHtml;
        }

        function attachActionListeners() {
            // Re-bind Edit Product
            document.querySelectorAll('.btn-edit-product').forEach(btn => {
                btn.onclick = function() {
                    const { id, name, price, offer, color, desc, category } = this.dataset;
                    currentProductId = id;
                    document.getElementById('productName').value = name;
                    document.getElementById('regularPrice').value = price;
                    document.getElementById('description').value = desc;
                    document.getElementById('color').value = color;
                    document.getElementById('category').value = category;
                    const regPrice = parseFloat(price);
                    const offPrice = parseFloat(offer);
                    document.getElementById('offerPrice').value = Math.floor(((regPrice - offPrice) / regPrice) * 100);
                    new bootstrap.Modal(document.getElementById('productModal')).show();
                };
            });

            // Re-bind Edit Images
            document.querySelectorAll('.btn-edit-images').forEach(btn => {
                btn.onclick = function() {
                    currentProductId = this.dataset.id;
                    const images = JSON.parse(this.dataset.images);
                    for(let i=0; i<4; i++){
                        const imgEl = document.getElementById(`imgDiv${i+1}`);
                        if(images[i]) { imgEl.src = images[i]; imgEl.style.display = "block"; }
                        else { imgEl.src = ""; imgEl.style.display = "none"; }
                    }
                    new bootstrap.Modal(document.getElementById('imageUploadModal')).show();
                };
            });

            // Re-bind Block/Unblock
            document.querySelectorAll('.btn-block-product').forEach(btn => {
                btn.onclick = function(e) { confirmBlock(e, this.dataset.id); };
            });
            document.querySelectorAll('.btn-unblock-product').forEach(btn => {
                btn.onclick = function(e) { confirmUnBlock(e, this.dataset.id); };
            });
        }

        // Initialize listeners
        attachActionListeners();
    </script>

