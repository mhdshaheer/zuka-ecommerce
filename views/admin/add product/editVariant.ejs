<%-include('../../views/partials/admin/adminHeader')%>
    <style>
    </style>
    <section class="content-main">
        <div class="content-header">
            <div>
                <h2 class="content-title card-title">Edit variant</h2>
                <p>Edit variant and stock management.</p>
            </div>

        </div>
        <div class="card mb-4">
            <header class="card-header">
                <div class="row gx-3">
                    <h4>
                        <%=product.productName%>
                    </h4>
                </div>
            </header>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th scope="col">Size</th>
                                <th scope="col">Price</th>
                                <th scope="col">Stock</th>
                                <th scope="col">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% product.variant.forEach((item, index)=> { %>
                                <tr>
                                    <td>
                                        <%= index + 1 %>
                                    </td>
                                    <td>
                                        <%= item.size %>
                                    </td>
                                    <td>
                                        <input type="number" value="<%= item.price %>"
                                            class="form-control form-control-sm" style="width: 80px;"
                                            id="variantPrice_<%= item._id %>" min="0" >

                                    </td>
                                    <td class="d-flex stockBox">

                                        <input type="number" value="<%= item.stock %>"
                                            class="form-control form-control-sm" style="width: 80px;"
                                            id="variantStock_<%= item._id %>" min="0">
                                                    <span><button class="btn btn-primary btn-sm ms-2"
                                                onclick="updatePriceStock('<%=product._id%>', '<%=item._id%>')">Update</button></span>
                                    </td>
                                    <td>
                                        <%if(item.isBlocked){%>
                                            <button class="btn btn-danger px-2"
                                                        onclick="unblockVariant('<%=product._id%>', '<%=item._id%>')">unblock</button>
                                                <%}else{%>
                                                    <button class="btn btn-primary"
                                                onclick="blockVariant('<%=product._id%>', '<%=item._id%>')">block</button>
                                                    
                                                    <%}%>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
            <div>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#variantModal">ADD +</button>
            </div>
    </section>

    <!-- modal -->
    <div class="modal fade" id="variantModal" tabindex="-1" aria-labelledby="variantModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="variantModalLabel">Add/Edit Variant</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="variantForm">
                        <!-- Size Field -->
                        <div class="mb-3">
                            <label for="variantSizeInput" class="form-label">Variant Size*</label>
                            <select class="form-control select-nice" id="variantSizeInput" name="variant_size" style="width: 100%;">
                                <option value="" disabled selected>Search or select size</option>
                                <optgroup label="General Sizes">
                                    <option value="XS">XS (Extra Small)</option>
                                    <option value="S">S (Small)</option>
                                    <option value="M">M (Medium)</option>
                                    <option value="L">L (Large)</option>
                                    <option value="XL">XL (Extra Large)</option>
                                    <option value="XXL">XXL (Double Extra Large)</option>
                                    <option value="3XL">3XL</option>
                                    <option value="4XL">4XL</option>
                                    <option value="5XL">5XL</option>
                                </optgroup>
                                <optgroup label="Waist Sizes (Inches)">
                                    <option value="28">28</option>
                                    <option value="30">30</option>
                                    <option value="32">32</option>
                                    <option value="34">34</option>
                                    <option value="36">36</option>
                                    <option value="38">38</option>
                                    <option value="40">40</option>
                                    <option value="42">42</option>
                                </optgroup>
                                <optgroup label="Shoe Sizes (UK)">
                                    <option value="UK 6">UK 6</option>
                                    <option value="UK 7">UK 7</option>
                                    <option value="UK 8">UK 8</option>
                                    <option value="UK 9">UK 9</option>
                                    <option value="UK 10">UK 10</option>
                                    <option value="UK 11">UK 11</option>
                                    <option value="UK 12">UK 12</option>
                                </optgroup>
                                <optgroup label="Shoe Sizes (US)">
                                    <option value="US 7">US 7</option>
                                    <option value="US 8">US 8</option>
                                    <option value="US 9">US 9</option>
                                    <option value="US 10">US 10</option>
                                    <option value="US 11">US 11</option>
                                    <option value="US 12">US 12</option>
                                    <option value="US 13">US 13</option>
                                </optgroup>
                            </select>
                        </div>
                        <!-- Price Field -->
                        <div class="mb-3">
                            <label for="variantPriceInput" class="form-label">Variant Price</label>
                            <input type="number" class="form-control" id="variantPriceInput" name="variant_price"
                                placeholder="Enter price">
                        </div>
                        <!-- Stock Field -->
                        <div class="mb-3">
                            <label for="variantStockInput" class="form-label">Variant Stock</label>
                            <input type="number" class="form-control" id="variantStockInput" name="variant_stock"
                                placeholder="Enter stock">
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary"
                        onclick="saveVariantData('<%=product._id%>')">Save</button>
                </div>
            </div>
        </div>
    </div>
    <!-- modal -->
    <%-include('../../views/partials/admin/adminFooter')%>

        <script>
            $(document).ready(function() {
                $('#variantSizeInput').select2({
                    dropdownParent: $('#variantModal'),
                    placeholder: "Search or select size",
                    allowClear: true,
                    width: '100%'
                });
            });

            function updatePriceStock(productId, variantId) {
                const variantPrice = document.getElementById('variantPrice_' + variantId);
                const variantStock = document.getElementById('variantStock_' + variantId);
                if(variantStock.value<0){
                    return Swal.fire({
                                title: 'Not valid!',
                                text: 'Stock must be greater than 0',
                                icon: 'warning',
                                confirmButtonText: 'Okay'
                            })
                }
                if(variantPrice.value<0){
                    return Swal.fire({
                                title: 'Not valid!',
                                text: 'Price must be greater than 0',
                                icon: 'warning',
                                confirmButtonText: 'Okay'
                            })
                }
                if (Number(variantPrice.value) > Number('<%=product.regularPrice%>')) {
                    return Swal.fire({
                        title: 'Not valid!',
                        text: 'Variant price cannot be greater than main product price (₹<%=product.regularPrice%>)',
                        icon: 'warning',
                        confirmButtonText: 'Okay'
                    })
                }
                Swal.fire({
                    title: 'Updating...',
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });
                axios.put(`/admin/products/${productId}/variants/${variantId}`, {
                    variantPrice: Number(variantPrice.value),
                    variantStock: Number(variantStock.value)
                })
                    .then((res) => {
                        if (res.status == 200) {
                            Swal.fire({
                                title: 'Success!',
                                text: 'Stock & price updated successfully!',
                                icon: 'success',
                                timer: 1500,
                                showConfirmButton: false
                            })
                        }
                    }).catch((error) => {
                        Swal.fire({
                            title: 'Error!',
                            text: 'Error occured while updating!',
                            icon: 'error',
                            confirmButtonText: 'Okay'
                        })
                    })
            }

            function blockVariant(productId, variantId) {
                Swal.fire({
                    title: 'Are you sure?',
                    text: "You want to block this variant!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Yes, block it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire({
                            title: 'Blocking...',
                            allowOutsideClick: false,
                            didOpen: () => Swal.showLoading()
                        });
                        axios.patch(`/admin/products/${productId}/variants/${variantId}/block`)
                            .then(res => {
                                if (res.status == 200) {
                                    const btnContainer = document.getElementById('variantPrice_' + variantId).closest('tr').querySelector('td:last-child');
                                    btnContainer.innerHTML = `<button class="btn btn-danger px-2" onclick="unblockVariant('${productId}', '${variantId}')">unblock</button>`;
                                    Swal.fire({
                                        title: 'Success!',
                                        text: 'Variant blocked successfully!',
                                        icon: 'success',
                                        timer: 1500,
                                        showConfirmButton: false
                                    });
                                }
                            }).catch(err => Swal.fire('Error', 'Failed to block variant', 'error'));
                    }
                });
            }

            function unblockVariant(productId, variantId) {
                Swal.fire({
                    title: 'Are you sure?',
                    text: "You want to unblock this variant!",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#28a745',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Yes, unblock it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire({
                            title: 'Unblocking...',
                            allowOutsideClick: false,
                            didOpen: () => Swal.showLoading()
                        });
                        axios.patch(`/admin/products/${productId}/variants/${variantId}/unblock`)
                            .then(res => {
                                if (res.status == 200) {
                                    const btnContainer = document.getElementById('variantPrice_' + variantId).closest('tr').querySelector('td:last-child');
                                    btnContainer.innerHTML = `<button class="btn btn-primary" onclick="blockVariant('${productId}', '${variantId}')">block</button>`;
                                    Swal.fire({
                                        title: 'Success!',
                                        text: 'Variant unblocked successfully!',
                                        icon: 'success',
                                        timer: 1500,
                                        showConfirmButton: false
                                    });
                                }
                            }).catch(err => Swal.fire('Error', 'Failed to unblock variant', 'error'));
                    }
                });
            }

            function saveVariantData(productId) {
                let productArr = []
                const variantSize = document.getElementById('variantSizeInput').value.trim();
                const variantPrice = document.getElementById('variantPriceInput').value.trim();
                const variantStock = document.getElementById('variantStockInput').value.trim();

                // validation

                if (!variantSize) {
                    Swal.fire({
                        title: 'Error!',
                        text: 'Variant size is required.',
                        icon: 'error',
                        confirmButtonText: 'Okay'
                    });
                    return;
                }

                if (!variantPrice || isNaN(variantPrice) || variantPrice <= 0) {
                    Swal.fire({
                        title: 'Error!',
                        text: 'Variant price must be a positive number.',
                        icon: 'error',
                        confirmButtonText: 'Okay'
                    });
                    return;
                }
                if (Number(variantPrice) > Number('<%=product.regularPrice%>')) {
                    Swal.fire({
                        title: 'Error!',
                        text: 'Variant price cannot be greater than main product price (₹<%=product.regularPrice%>)',
                        icon: 'error',
                        confirmButtonText: 'Okay'
                    });
                    return;
                }

                if (!variantStock || isNaN(variantStock) || variantStock < 0) {
                    Swal.fire({
                        title: 'Error!',
                        text: 'Variant stock must be a non-negative number.',
                        icon: 'error',
                        confirmButtonText: 'Okay'
                    });
                    return;
                }

                Swal.fire({
                    title: 'Adding variant...',
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });
                axios.post(`/admin/products/${productId}/variants`, {
                    variantSize: variantSize.toUpperCase(),
                    variantPrice,
                    variantStock
                })
                    .then(res => {
                        const tbody = document.querySelector('tbody')
                        tbody.innerHTML = ''
                        if (res.status == 200) {
                            Swal.fire({
                                title: 'Success!',
                                text: 'Variant Added successfully!',
                                icon: 'success',
                                confirmButtonText: 'Okay'
                            });
                            const product = res.data.product;
                            product.variant.forEach((item, index) => {
                                let element = `
                                            <tr>
                                                <td>
                                                    ${index + 1}
                                                </td>
                                                <td>
                                                    ${item.size}
                                                </td>
                                                <td>
                                                    <input type="number" value="${item.price}"
                                                        class="form-control form-control-sm" style="width: 80px;"
                                                        id="variantPrice_${item._id}">
                                                </td>
                                                <td class="d-flex stockBox">
                                                    <input type="number" value="${item.stock}"
                                                        class="form-control form-control-sm" style="width: 80px;"
                                                        id="variantStock_${item._id}">
                                                    <span><button class="btn btn-primary btn-sm ms-2"
                                                            onclick="updatePriceStock('${productId}', '${item._id}')">Update</button></span>
                                                </td>
                                                <td>
                                                    ${item.isBlocked
                                        ? `<button class="btn btn-danger px-2" onclick="unblockVariant('${productId}', '${item._id}')">unblock</button>`
                                        : `<button class="btn btn-primary" onclick="blockVariant('${productId}', '${item._id}')">block</button>`
                                    }
                                                </td>
                                            </tr>
                                        `;
                                productArr += element;
                            });
                            tbody.innerHTML = productArr;

                        }
                    }).catch(error => {
                        if (error.response) {
                            Swal.fire({
                                title: 'Error!',
                                text: error.response.data.message,
                                icon: 'error',
                                confirmButtonText: 'Okay'
                            });
                        } else {
                            Swal.fire({
                                title: 'Error!',
                                text: 'Having issues on variant adding!',
                                icon: 'error',
                                confirmButtonText: 'Okay'
                            });

                        }
                    })
            }
        </script>
