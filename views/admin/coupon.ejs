<%-include('../../views/partials/admin/adminHeader')%>
<style>
    .blockBtn{
        background-color: red !important;
    }
</style>
            <section class="content-main">
                <div class="content-header">
                    <div>
                        <h2 class="content-title card-title">Coupon Mangement</h2>
                    </div>
                    <div>
                        <a href="#" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createCouponModal">
                            <i class="text-muted material-icons md-post_add"></i>
                            Add Coupon
                        </a>
                    </div>
                </div>
                <div class="card mb-4">
                   
                    <!-- card-header end// -->
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>No</th>
                                        <th scope="col">Coupon Code</th>
                                        <th scope="col">Discount Value</th>
                                        <th scope="col">Min Amount</th>
                                        <th scope="col">Activation Date</th>
                                        <th scope="col">Expiry Date</th>
                                        <th scope="col" class="text-center">Coupon used</th>
                                        <th scope="col">Status</th>
                                        <th scope="col" class="text-end">Action</th>
                                    </tr>
                                </thead>
                        <tbody id="couponTableBody">
                            <%coupon.map((item,index)=>{%>
                                <tr>
                                    <td><%=index+1%></td>
                                    <td><b><%=item.code%></b></td>
                                    <td><%=item.discountPrice%></td>
                                    <td><%=item.minimumPrice%></td>
                                    <td><%=item.createdOn.toLocaleDateString()%></td>
                                    <td><%=item.expireOn.toLocaleDateString()%></td>
                                    <td class="text-center"><%=item.userId.length%></td>
                                    <td><span class="badge rounded-pill <%=item.isList?'alert-success':'alert-danger'%>"><%=item.isList?'Active':'Inactive'%></span></td>
                                    <td class="text-end">
                                        <%if(item.isList){%>
                                            <button class="btn btn-md rounded font-sm blockBtn text-white" onclick="confirmBlock('<%=item._id%>')">Block</button>
                                        <%}else{%>
                                            <button class="btn btn-md rounded font-sm btn-brand" onclick="confirmUnBlock('<%=item._id%>')">Unblock</button>
                                        <%}%>
                                    </td>
                                </tr>
                            <%})%>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="pagination-area mt-15 mb-50" id="paginationArea">
            <nav aria-label="Page navigation example">
                <ul class="pagination justify-content-start">
                <% for (let i = 1; i <= totalPages; i++) { %>
                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                    <a class="page-link" href="/admin/coupons?page=<%= i %>"><%= i %></a>
                    </li>
                <% } %>
                </ul>
            </nav>
        </div>
    </section>

    <!-- Modal -->
    <div class="modal fade" id="createCouponModal" tabindex="-1" aria-labelledby="createCouponModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="createCouponModalLabel">Create New Coupon</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="couponForm">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="couponCode" class="form-label">Coupon Code</label>
                            <input type="text" class="form-control" id="couponCode" placeholder="Enter coupon code" required>
                            <div id="couponError" class="text-danger"></div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="minAmount" class="form-label">Minimum Amount</label>
                                <input type="number" class="form-control" id="minAmount" placeholder="Enter minimum amount" required>
                                <div id="minAmountError" class="text-danger"></div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="discountValue" class="form-label">Discount Value</label>
                                <input type="number" class="form-control" id="discountValue" placeholder="Enter discount value" required>
                                <div id="discountValueError" class="text-danger"></div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="activationDate" class="form-label">Activation Date</label>
                                <input type="date" class="form-control" id="activationDate" required>
                                <div id="activateDateError" class="text-danger"></div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="expiryDate" class="form-label">Expiry Date</label>
                                <input type="date" class="form-control" id="expiryDate" required>
                                <div id="expiryDateError" class="text-danger"></div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary" id="saveCouponBtn">Save Coupon</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const couponCode = document.getElementById('couponCode');
        const minAmount = document.getElementById('minAmount');
        const discountValue = document.getElementById('discountValue');
        const activationDate = document.getElementById('activationDate');
        const expiryDate = document.getElementById('expiryDate');
        const couponTableBody = document.getElementById('couponTableBody');
        const paginationArea = document.getElementById('paginationArea');

        document.getElementById('saveCouponBtn').addEventListener('click', (e) => {
            e.preventDefault();
            const currentDate = new Date();
            currentDate.setDate(currentDate.getDate() - 1);
            const startDate = new Date(activationDate.value);
            const endDate = new Date(expiryDate.value);

            if(!couponCode.value.trim()){
                document.getElementById('couponError').innerHTML = "coupon code should not be empty";
                return;
            } else { document.getElementById('couponError').innerHTML = ''; }

            if(!minAmount.value.trim() || Number(minAmount.value) < 0){
                document.getElementById('minAmountError').innerHTML = "Enter a valid positive amount";
                return;
            } else { document.getElementById('minAmountError').innerHTML = ''; }

            if(!discountValue.value.trim() || Number(discountValue.value) < 0 || Number(discountValue.value) > Number(minAmount.value)){
                document.getElementById('discountValueError').innerHTML = "Invalid discount value";
                return;
            } else { document.getElementById('discountValueError').innerHTML = ''; }

            if(!activationDate.value.trim() || currentDate > startDate){
                document.getElementById('activateDateError').innerHTML = "Date is not valid";
                return;
            } else { document.getElementById('activateDateError').innerHTML = ''; }

            if(!expiryDate.value.trim() || currentDate > endDate){
                document.getElementById('expiryDateError').innerHTML = "Date is not valid";
                return;
            } else { document.getElementById('expiryDateError').innerHTML = ''; }

            axios.post('/admin/coupons', {
                couponCode: couponCode.value.toUpperCase(),
                minAmount: minAmount.value,
                discountValue: discountValue.value,
                activationDate: new Date(activationDate.value),
                expiryDate: new Date(expiryDate.value)
            }).then((res) => {
                if(res.status == 200){
                    Swal.fire({ title: 'Success!', text: 'Coupon Created successfully!', icon: 'success' })
                    .then(() => {
                        fetchCoupons(1);
                        bootstrap.Modal.getInstance(document.getElementById('createCouponModal')).hide();
                        document.getElementById('couponForm').reset();
                    });
                }
            }).catch(err => {
                if(err.response && err.response.status == 400){
                    Swal.fire({ title: 'Already exist!', text: 'Coupon already exist!', icon: 'warning' });
                }
            });
        });

        async function fetchCoupons(page = 1) {
            try {
                const response = await axios.get(`/admin/coupons?page=${page}&ajax=true`);
                const { coupon, totalPages, currentPage } = response.data;
                updateTable(coupon);
                updatePagination(currentPage, totalPages);
                window.history.pushState({}, '', `/admin/coupons?page=${currentPage}`);
            } catch (error) {
                console.error(error);
                Swal.fire('Error', 'Failed to fetch coupon data', 'error');
            }
        }

        function updateTable(coupons) {
            couponTableBody.innerHTML = coupons.length ? coupons.map((item, index) => `
                <tr>
                    <td>${index + 1}</td>
                    <td><b>${item.code}</b></td>
                    <td>${item.discountPrice}</td>
                    <td>${item.minimumPrice}</td>
                    <td>${new Date(item.createdOn).toLocaleDateString()}</td>
                    <td>${new Date(item.expireOn).toLocaleDateString()}</td>
                    <td class="text-center">${item.userId ? item.userId.length : 0}</td>
                    <td><span class="badge rounded-pill ${item.isList ? 'alert-success' : 'alert-danger'}">${item.isList ? 'Active' : 'Inactive'}</span></td>
                    <td class="text-end">
                        ${item.isList ? 
                            `<button class="btn btn-md rounded font-sm blockBtn text-white" onclick="confirmBlock('${item._id}')">Block</button>` : 
                            `<button class="btn btn-md rounded font-sm btn-brand" onclick="confirmUnBlock('${item._id}')">Unblock</button>`
                        }
                    </td>
                </tr>
            `).join('') : '<tr><td colspan="9" class="text-center">No coupons found</td></tr>';
        }

        function updatePagination(currentPage, totalPages) {
            let html = '<nav aria-label="Page navigation example"><ul class="pagination justify-content-start">';
            for (let i = 1; i <= totalPages; i++) {
                html += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                    <a class="page-link" href="/admin/coupons?page=${i}">${i}</a>
                </li>`;
            }
            html += '</ul></nav>';
            paginationArea.innerHTML = html;
        }

        async function confirmBlock(couponId) {
            const result = await Swal.fire({
                title: 'Are you sure?',
                text: "Block this coupon?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, block!'
            });
            if (result.isConfirmed) {
                try {
                    const res = await axios.patch(`/admin/coupons/${couponId}/block`);
                    if (res.status == 200) {
                        Swal.fire('Blocked!', 'Coupon blocked.', 'success');
                        fetchCoupons(new URLSearchParams(window.location.search).get('page') || 1);
                    }
                } catch (error) { Swal.fire('Error', 'Action failed', 'error'); }
            }
        }

        async function confirmUnBlock(couponId) {
            const result = await Swal.fire({
                title: 'Are you sure?',
                text: "Unblock this coupon?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, unblock!'
            });
            if (result.isConfirmed) {
                try {
                    const res = await axios.patch(`/admin/coupons/${couponId}/unblock`);
                    if (res.status == 200) {
                        Swal.fire('Unblocked!', 'Coupon active.', 'success');
                        fetchCoupons(new URLSearchParams(window.location.search).get('page') || 1);
                    }
                } catch (error) { Swal.fire('Error', 'Action failed', 'error'); }
            }
        }

        document.addEventListener('click', (e) => {
            const link = e.target.closest('.page-link');
            if (link) {
                e.preventDefault();
                const url = new URL(link.href, window.location.origin);
                const page = url.searchParams.get('page');
                fetchCoupons(page);
            }
        });
    </script>
<%-include('../../views/partials/admin/adminFooter')%>    
